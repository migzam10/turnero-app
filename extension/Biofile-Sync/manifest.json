{
  "manifest_version": 3,
  "name": "Turnero — Biofile Sync",
  "version": "1.0.0",
  "description": "Sincroniza pacientes de Biofile con el sistema de turnos",
  "key": "",
  "permissions": [
    "alarms",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://*.biofile.com.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Turnero"
  }
}
