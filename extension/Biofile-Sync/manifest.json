{
  "manifest_version": 3,
  "name": "Turnero CertiMedic — Biofile Sync",
  "version": "1.0.0",
  "description": "Sincroniza pacientes de Biofile con el sistema de turnos",
  "key": "",
  "permissions": ["alarms", "storage", "tabs", "scripting"],
  "host_permissions": [
    "*://ipscertimedic.biofile.com.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Turnero CertiMedic"
  }
}
