{
  "manifest_version": 3,
  "name": "Inyector Turnero a Biofile",
  "version": "1.1",
  "description": "Lista pacientes del Turnero y los inyecta en Biofile mediante clic.",
  "key": "",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "http://*/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.biofile.com.co/Factura/OrdenesServiciosSaludOcupacional.aspx*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
