# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=turnero
DB_USER=turnero_user
DB_PASSWORD=CambiarEsto2026

# ── App ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Seguridad ─────────────────────────────────────────────────
# Debe coincidir con el valor en la extensión Chrome
EXTENSION_SECRET=cambiar_este_secreto_en_produccion

# ── Admin (protección básica opcional) ───────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=CambiarEsto2026

# ── Edición del producto (licencia) ──────────────────────────
# basica = solo sonido | plus = sonido + anuncio por voz (TTS).
# La fija el instalador; el cliente NO la cambia desde el panel. Sin este valor
# se asume 'basica' (sin voz). En Plus, la voz además debe activarse desde Admin.
EDICION=basica

# ── TTS (anuncio por voz en las pantallas TV) — solo si EDICION=plus ─
# Motor de voz: espeak (dev/Docker) | piper (prod, neuronal) | sapi (Windows) | say (macOS)
TTS_ENGINE=espeak
# Solo si TTS_ENGINE=piper (rutas dejadas por scripts/setup-tts.*):
# PIPER_BIN=vendor/tts/piper/piper
# PIPER_MODEL=vendor/tts/models/es_ES-sharvard-medium.onnx
# PIPER_SPEAKER=1   # sharvard tiene 2 voces; la 1 es la femenina elegida
# Ritmo de la voz (opcional): length_scale >1 = más lento; silencio entre frases (seg):
# PIPER_LENGTH_SCALE=1.25
# PIPER_SENTENCE_SILENCE=0.4
# Solo si TTS_ENGINE=sapi (Windows); vacío = voz por defecto del SO:
# VOZ_SAPI=Microsoft Sabina Desktop
